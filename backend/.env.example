NODE_ENV=development
PORT=5000
API_VERSION=v1

MONGODB_URI=mongodb://resculance:resculance@46.202.163.218:27017/resculance?authSource=resculance


JWT_SECRET=dev-only-secret-change-me-to-a-long-random-string
JWT_REFRESH_SECRET=dev-only-refresh-secret-change-me-too
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

BCRYPT_ROUNDS=10

CORS_ORIGIN=http://localhost:5173
SOCKET_CORS_ORIGIN=http://localhost:5173

# Mediasoup was removed — video calls are handled by Jitsi (meet.jit.si),
# the backend has no media-server role. You can safely delete the
# UDP 40000-49999 firewall rule that used to be required for the SFU.

UPLOAD_DIR=uploads

# --- Object storage (MinIO) --------------------------------------------------
# All user-uploaded artefacts (profile images, session files) go to MinIO.
# Setting MINIO_USE_SSL=true means we'll talk HTTPS on the configured port.
# MINIO_PUBLIC_BASE_URL is optional — set it only if your bucket is fronted
# by a public CDN/domain different from the API endpoint.
MINIO_ENDPOINT=storage.distrx.io
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=SuperStrongPassword123
MINIO_BUCKET=resculance
# MINIO_PUBLIC_BASE_URL=https://cdn.example.com/resculance
# Pre-signed download URL lifetime in seconds (default 3600 = 1 hour).
# MINIO_PRESIGN_TTL_SECONDS=3600

# --- Logging -----------------------------------------------------------------
# debug | info | warn | error (defaults to info)
# LOG_LEVEL=info

SUPERADMIN_EMAIL=admin@resulance.local
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=Admin@12345
SUPERADMIN_FIRST_NAME=Super
SUPERADMIN_LAST_NAME=Admin
