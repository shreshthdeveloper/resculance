# ===========================================
# Resulance Backend - Environment Variables
# ===========================================

# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/resulance
# For production / Atlas:
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/resulance?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Password hashing
BCRYPT_ROUNDS=10

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173
SOCKET_CORS_ORIGIN=http://localhost:5173

# Mediasoup
# In production, set to the public IP of the server
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_MIN_PORT=40000
MEDIASOUP_MAX_PORT=49999

# Uploads (relative to project root)
UPLOAD_DIR=uploads

# Optional rate limit overrides
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# Seed superadmin defaults (used by `npm run seed`)
SUPERADMIN_EMAIL=admin@resulance.local
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=Admin@12345
SUPERADMIN_FIRST_NAME=Super
SUPERADMIN_LAST_NAME=Admin
