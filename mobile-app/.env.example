# resculance mobile app — example env. Copy to `.env` and edit.
#
# On the iOS simulator you can use http://localhost:5000 — the simulator shares
# the host network. On Android emulator use http://10.0.2.2:5000.
# On a physical device (Expo Go), the phone is NOT on localhost — use your
# Mac's LAN IP, e.g. http://192.168.1.42:5000. Find it with:
#   ipconfig getifaddr en0
# The backend must be reachable from your phone (same Wi-Fi, no firewall block).

EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1

# Optional. Defaults to EXPO_PUBLIC_API_URL with the trailing /api/vN stripped,
# which matches how the backend mounts Socket.IO. Override only if your socket
# server lives on a different origin.
# EXPO_PUBLIC_SOCKET_URL=http://localhost:5000
